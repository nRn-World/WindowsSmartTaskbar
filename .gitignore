# .gitignore for .NET
bin/
obj/
*.user
*.userosscache
*.sln.docstates

# User-specific files
.vs/
.idea/
.vscode/

# Build logs
*.log
build_output.txt
build_err.txt
build_*.txt

# Application data
programs.json
categories.json
settings.json

# Build outputs
Release/
publish_output/
publish_selfcontained/
publish_small/
publish_new/
publish_release/
plans/*.dll
plans/*.exe
plans/*.pdb
*.zip
*.pdb

# Secrets and env files
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# OS/system files
.DS_Store
Thumbs.db

# Common build/dependency folders
dist/
out/
node_modules/
